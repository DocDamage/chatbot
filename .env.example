PORT=3001
NODE_ENV=development
JWT_SECRET=replace-with-at-least-32-random-characters
CORS_ORIGIN=http://localhost:3000

USE_OLLAMA=true
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama2

ENABLE_RAG=true
RAG_PERSISTENCE=true
RAG_DATABASE_URL=postgresql://chatbot:chatbot@localhost:5432/chatbot
RAG_SQLITE_PATH=./data/chatbot.db
EMBEDDING_PROVIDER=xenova
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

ENABLE_REDIS_CACHE=true
REDIS_URL=redis://localhost:6379

ENABLE_TOOL_CALLING=true
ENABLE_BASH_EXECUTOR=false
ENABLE_WEBSOCKET=true

# Required before live SEC API access. Use a real contact string for SEC fair access.
SEC_USER_AGENT=DocDamageChatbot/1.0 contact@example.com
SEC_DATA_DIR=./data/sec
SEC_MAX_REQUESTS_PER_SECOND=8

LOCAL_TOOLS_DIR=./local-tools
PRIVATE_TOOL_BUNDLES_DIR=./data/tools/private-bundles
SPRITE_LAB_DIR=./data/sprite-lab
AUDIO_LAB_DIR=./data/audio-lab
