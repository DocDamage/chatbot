# Server Configuration
PORT=3001
NODE_ENV=development

# LLM Provider Configuration
LLM_PROVIDER=template
# Option 1: Use Ollama (free, local)
USE_OLLAMA=false
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama2
# Other free Ollama models: llama3, mistral, codellama, phi, gemma

# Option 2: Use Hugging Face (free, API, rate limited)
# USE_OLLAMA=false
# USE_HUGGINGFACE=true
# HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.2
# HUGGINGFACE_API_KEY=your_hf_api_key_here (optional, for higher rate limits)

# Option 3: Use OpenAI (requires API key, paid)
# USE_OLLAMA=false
# USE_HUGGINGFACE=false
# OPENAI_API_KEY=your_openai_api_key_here

# Option 4: Use an OpenAI-compatible provider
# LLM_PROVIDER=openai-compatible
# OPENAI_COMPATIBLE_PROVIDER_NAME=deepseek
# OPENAI_COMPATIBLE_API_KEY=your_provider_key_here
# OPENAI_COMPATIBLE_BASE_URL=https://api.deepseek.com
# OPENAI_COMPATIBLE_MODEL=deepseek-chat

# Option 5: Use Anthropic Claude
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your_anthropic_key_here
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Option 6: Use Google Gemini
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_key_here
# GEMINI_MODEL=gemini-1.5-flash

# Image Generation (Stable Diffusion)
USE_STABLE_DIFFUSION=false
STABLE_DIFFUSION_URL=http://localhost:7860

# Feature Flags
ENABLE_CONTRACTS=true
ENABLE_MEMORY=true
ENABLE_PROVENANCE=true
ENABLE_CACHING=true

# Phase 1: Advanced Features (BLEEDING_EDGE_ROADMAP)
ENABLE_RAG=true
ENABLE_MODEL_ROUTING=true
ENABLE_ENSEMBLE=false
ENABLE_SAFETY_PIPELINE=true
ENABLE_SEMANTIC_CACHE=true

# RAG Configuration
RAG_TOP_K=10
RAG_SIMILARITY_THRESHOLD=0.7

# Model Routing Configuration
MODEL_ROUTING_ENABLED=true
ENSEMBLE_ENABLED=false

# Safety Configuration
SAFETY_CHECK_FACTS=true
SAFETY_CONFIDENCE_THRESHOLD=0.7

# Semantic Cache Configuration
SEMANTIC_CACHE_TTL=3600
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.7

# Embedding Configuration
# "xenova" is kept as a backward-compatible alias for local Transformers.js embeddings.
EMBEDDING_PROVIDER=xenova
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
EMBEDDING_USE_TRANSFORMERS=false
# For OpenAI embeddings:
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small

# Multi-Level Cache Configuration
REDIS_URL=redis://localhost:6379
DISK_CACHE_DIR=./cache
ENABLE_REDIS_CACHE=true
ENABLE_DISK_CACHE=true

# Vision Configuration
# Option 1: Use LLaVA via Ollama (free, local)
USE_LLAVA=true
LLAVA_MODEL=llava
# Setup: ollama pull llava

# Option 2: Use Gemini Vision (requires API key, paid)
# USE_LLAVA=false
# GEMINI_API_KEY=your_gemini_api_key_here
# USE_GEMINI_VISION=true

# Option 3: Use GPT-4V (requires OpenAI API key, paid)
# USE_LLAVA=false
# USE_GPT4V=true

# Limits
MAX_COST_PER_REQUEST=0.10
MAX_LATENCY_MS=5000
MAX_RETRIES=3

# Logging
LOG_LEVEL=info

