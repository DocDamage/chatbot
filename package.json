{
  "name": "ai-chatbot-hub",
  "version": "1.0.0",
  "description": "Production-grade AI chatbot with contract-based control, memory stratification, and provider abstraction",
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "cd client && npm run dev",
    "build": "tsc && cd client && npm run build",
    "build:server": "tsc",
    "start": "node dist/server/index.js",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "chatbot",
    "llm",
    "rag"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@xenova/transformers": "^2.17.1",
    "axios": "^1.13.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "node-cache": "^5.1.2",
    "openai": "^4.20.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4",
    "ml-distance": "^2.1.1",
    "natural": "^6.12.0",
    "@anthropic-ai/sdk": "^0.20.0",
    "ioredis": "^5.3.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/uuid": "^9.0.8",
    "@types/natural": "^5.1.5",
    "concurrently": "^8.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
