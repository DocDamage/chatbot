{
  "name": "ai-chatbot-hub",
  "version": "1.0.0",
  "description": "Production-grade AI chatbot with contract-based control, memory stratification, and provider abstraction",
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "cd client && npm run dev",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc",
    "build:client": "cd client && npm run build",
    "start": "node dist/server/index.js",
    "start:prod": "npm run build && npm start",
    "type-check": "npm run type-check:server && npm run type-check:tests && npm run type-check:client",
    "type-check:server": "tsc --noEmit",
    "type-check:tests": "tsc --noEmit -p tsconfig.tests.json",
    "type-check:client": "cd client && npm run type-check",
    "release:check": "npm run release:server && npm run release:client && npm run release:package",
    "release:server": "npm run type-check:server && npm run type-check:tests && npm run lint:server && npm run test:release && npm run test:coverage -- --runInBand",
    "release:client": "npm run type-check:client && npm run lint:client && cd client && npm run test && npm run coverage && npm run a11y",
    "release:package": "npm run smoke:package",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=__tests__",
    "test:integration": "jest --testPathPattern=server/__tests__",
    "test:security": "jest --runTestsByPath src/server/__tests__/release-security.test.ts",
    "test:routes": "jest --runTestsByPath src/server/routeManifest.test.ts src/server/chatRequest.test.ts src/types/chat.test.ts src/middleware/apiErrorSchema.test.ts src/server/routes/setup.test.ts src/server/routes/__tests__/feature-expansion-routes.test.ts",
    "test:services": "jest --runTestsByPath src/core/agents/PatchGenerator.test.ts src/core/config/APIKeyManager.test.ts src/core/conversation/ConversationManager.test.ts src/core/files/FileExplorerService.test.ts src/core/initialization/ServiceInitializer.test.ts src/core/knowledge/OnlineKnowledgeIngestionService.test.ts",
    "test:release": "npm run test:security -- --runInBand && npm run test:routes -- --runInBand && npm run test:services -- --runInBand && npm run test:e2e -- --runInBand",
    "test:e2e": "jest --testPathPattern=e2e",
    "smoke:package": "npm run build && node scripts/verify-package-smoke.mjs",
    "eval:rag": "tsx scripts/run-evals.ts rag",
    "eval:safety": "tsx scripts/run-evals.ts safety",
    "eval:all": "tsx scripts/run-evals.ts all",
    "eval:math": "tsx scripts/run-domain-evals.ts math",
    "eval:market": "tsx scripts/run-domain-evals.ts market",
    "eval:gamedev": "tsx scripts/run-domain-evals.ts gamedev",
    "eval:genius": "tsx scripts/run-domain-evals.ts all",
    "eval:sixsigma": "tsx scripts/run-domain-evals.ts sixsigma",
    "eval:blackbelt": "tsx scripts/run-domain-evals.ts sixsigma",
    "eval:popculture": "tsx scripts/run-domain-evals.ts popculture",
    "eval:history": "tsx scripts/run-domain-evals.ts history",
    "eval:science": "tsx scripts/run-domain-evals.ts science",
    "eval:chrono": "tsx scripts/run-domain-evals.ts all",
    "eval:music": "tsx scripts/run-domain-evals.ts music",
    "eval:suno": "tsx scripts/run-domain-evals.ts music/suno",
    "eval:daw": "tsx scripts/run-domain-evals.ts music/daw",
    "eval:story": "tsx scripts/run-domain-evals.ts story",
    "eval:legal": "tsx scripts/run-domain-evals.ts legal",
    "eval:health": "tsx scripts/run-domain-evals.ts health",
    "eval:security": "tsx scripts/run-domain-evals.ts security",
    "eval:business": "tsx scripts/run-domain-evals.ts business",
    "eval:philosophy": "tsx scripts/run-domain-evals.ts philosophy",
    "eval:language": "tsx scripts/run-domain-evals.ts language",
    "eval:geography": "tsx scripts/run-domain-evals.ts geography",
    "eval:engineering": "tsx scripts/run-domain-evals.ts engineering",
    "eval:nlu": "tsx scripts/run-domain-evals.ts nlu",
    "eval:knowledge-os": "tsx scripts/run-domain-evals.ts knowledge-os",
    "import:general": "tsx scripts/import-wikipedia-general-corpus.ts",
    "lint": "npm run lint:server && npm run lint:client",
    "lint:server": "eslint src",
    "lint:client": "eslint client/src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "keywords": [
    "ai",
    "chatbot",
    "llm",
    "rag"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.9",
    "@google/generative-ai": "^0.24.1",
    "@huggingface/transformers": "^4.2.0",
    "@toon-format/toon": "^2.1.0",
    "axios": "^1.13.2",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.0.0-rc.12",
    "compromise": "^14.14.5",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.2",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "^8.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "ml-distance": "^2.1.1",
    "multer": "^1.4.5-lts.1",
    "natural": "^6.12.0",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "openai": "^4.20.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.16.3",
    "puppeteer": "^24.34.0",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "twilio": "^5.11.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "ws": "^8.16.0",
    "xml2js": "^0.6.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/natural": "^5.1.5",
    "@types/node": "^20.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/pdf-parse": "^1.1.4",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.4",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
