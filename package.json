{
  "name": "ai-chatbot-hub",
  "version": "1.0.0",
  "description": "Production-grade AI chatbot with contract-based control, memory stratification, and provider abstraction",
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "cd client && npm run dev",
    "build": "tsc && cd client && npm run build",
    "build:server": "tsc",
    "start": "node dist/server/index.js",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=__tests__",
    "test:integration": "jest --testPathPattern=server/__tests__",
    "test:e2e": "jest --testPathPattern=e2e",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "keywords": [
    "ai",
    "chatbot",
    "llm",
    "rag"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@xenova/transformers": "^2.17.1",
    "axios": "^1.13.2",
    "better-sqlite3": "^12.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "axios": "^1.13.2",
    "cheerio": "^1.0.0-rc.12",
    "csv-parse": "^5.5.2",
    "xml2js": "^0.6.2",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "ml-distance": "^2.1.1",
    "natural": "^6.12.0",
    "node-cache": "^5.1.2",
    "openai": "^4.20.1",
    "pdf-parse": "^1.1.1",
    "better-sqlite3": "^9.2.2",
    "pg": "^8.16.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "ws": "^8.16.0",
    "zod": "^3.22.4",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/natural": "^5.1.5",
    "@types/node": "^20.10.5",
    "@types/pdf-parse": "^1.1.4",
    "@types/pg": "^8.10.9",
    "@types/better-sqlite3": "^7.6.8",
    "@types/multer": "^1.4.11",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.5.10",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.4",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
